# ===============================
# CONFIGURATION BASE DE DONNÉES
# ===============================

# PostgreSQL (Production - Render)
DB_HOST=your-render-postgres-host.render.com
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name
DB_PORT=5432

# MongoDB (Optionnel si utilisé)
MONGO_URI=mongodb://localhost:27017/cinephoria
MONGO_DB_NAME=cinephoria

# ===============================
# CONFIGURATION SERVEUR
# ===============================

PORT=3000
NODE_ENV=development

# ===============================
# JWT / AUTHENTIFICATION
# ===============================

JWT_SECRET=votre_cle_secrete_super_longue_et_complexe_ici
JWT_EXPIRES_IN=1d

# ===============================
# NODEMAILER / ENVOI D'EMAILS
# ===============================

# Mailtrap (développement/test)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASSWORD=your_mailtrap_password

# Production: utilisez un vrai service SMTP (Gmail, SendGrid, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ===============================
# URLS ET EMAILS
# ===============================

FRONTEND_URL=http://localhost:3000
CONTACT_EMAIL=contact@cinephoria.fr

# ===============================
# PARAMÈTRES APPLICATION
# ===============================

TEMP_PASSWORD_LENGTH=12
